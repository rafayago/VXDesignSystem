{
  "name": "@vortx/design-tokens",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": "./styles.css",
    "./styles.css": "./styles.css",
    "./themes/gray": "./themes/gray.css",
    "./themes/gray-vega": "./themes/gray-vega.css",
    "./typography": "./typography.css",
    "./motion": "./motion.css",
    "./charts": "./charts.css"
  },
  "files": [
    "src",
    "styles.css",
    "typography.css",
    "motion.css",
    "charts.css",
    "themes"
  ],
  "scripts": {
    "build": "echo 'No build step required for CSS token package'",
    "dev": "echo 'Design tokens are consumed directly as CSS'",
    "lint": "echo 'No lint configured yet'",
    "typecheck": "echo 'No typecheck step for CSS package'",
    "clean": "rm -rf dist"
  }
}
