{
  "name": "@vortx/design-tokens",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": "./src/index.css",
    "./styles.css": "./src/index.css",
    "./tokens": "./src/tokens/index.css",
    "./themes/light": "./src/themes/light.css",
    "./themes/dark": "./src/themes/dark.css",
    "./themes/gray": "./src/themes/gray.css",
    "./themes/gray-vega": "./src/themes/gray-vega.css"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "build": "echo 'No build step required for CSS token package'",
    "dev": "echo 'Design tokens are consumed directly as CSS'",
    "lint": "echo 'No lint configured yet'",
    "typecheck": "echo 'No typecheck step for CSS package'",
    "clean": "rm -rf dist",
    "export:figma": "node scripts/export-tokens.mjs"
  }
}
