{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "es2022"],
    "allowJs": false,
    "incremental": true,
    "noEmit": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["../../packages/ui/src/*"]
    }
  },
  "include": [
    "**/*.css",
    "**/*.js",
    "**/*.mjs",
    "**/*.scss",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts" ],
  "exclude": [
    "node_modules",
    "dist",
    "build",
    ".next"
  ]
}
